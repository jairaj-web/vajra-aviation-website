# ============================================================
# VAJRA AVIATION - Hostinger / LiteSpeed .htaccess
# ============================================================

RewriteEngine On

# Force index.html before index.php (prevents WordPress from intercepting homepage)
DirectoryIndex index.html index.php

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www (canonical domain)
RewriteCond %{HTTP_HOST} ^www\.vajraaviation\.com [NC]
RewriteRule ^(.*)$ https://vajraaviation.com/$1 [L,R=301]

# ── LITESPEED CACHE CONTROL ────────────────────────────────
# LiteSpeed caching handled by mod_expires and mod_headers below

# ── OLD WORDPRESS URL REDIRECTS (must be before trailing slash rule) ──
RewriteRule ^easa-part-66-training-india/?$ /course-easa-part-66 [R=301,L]
RewriteRule ^easa-part-66-j/?$ /course-easa-part-66 [R=301,L]
RewriteRule ^graduate-engineering-training/?$ /course-graduate-engineering [R=301,L]
RewriteRule ^charter-services/?$ / [R=301,L]
RewriteRule ^luxury-aviation-tailored-solutions-for-need-premier-services/?$ / [R=301,L]
RewriteRule ^redefining-luxury-the-private-jet-experience-like-never-before/?$ / [R=301,L]
RewriteRule ^redefining-luxury-the-private-jet-experience-like-never-before-copy-copy/?$ / [R=301,L]
RewriteRule ^behind-the-scenes-of-private-jet-we-make-your-flight-seamless/?$ / [R=301,L]
RewriteRule ^the-safest-way-to-fly-why-private-jets-are-the-future-of-secure-travel/?$ / [R=301,L]
RewriteRule ^skip-the-crowds-fly-in-comfort-the-freedom-of-private-jet-travel/?$ / [R=301,L]
RewriteRule ^flying-private-is-the-new-standard-of-comfort/?$ / [R=301,L]
RewriteRule ^tag/.*$ /blog [R=301,L]
RewriteRule ^category/.*$ /blog [R=301,L]
RewriteRule ^author/.*$ /about [R=301,L]

# ── CLEAN URLs (remove .html extension) ────────────────────
# Redirect .html requests to clean URL (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ── REMOVE TRAILING SLASH (avoid duplicate URLs) ───────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# Internally serve the .html file for clean URL requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Old faculty/classroom URLs (keep working)
RewriteRule ^faculty$ /facility-faculty [R=301,L]
RewriteRule ^classroom$ /facility-classroom [R=301,L]
RewriteRule ^about-us/?$ /about [R=301,L]
RewriteRule ^about-us\.html$ /about [R=301,L]
RewriteRule ^membership-pricing/?$ /contact [R=301,L]
RewriteRule ^membership/?$ /contact [R=301,L]
RewriteRule ^pricing/?$ /contact [R=301,L]
RewriteRule ^aircraft-sourcing-sales/?$ /egca-services [R=301,L]
RewriteRule ^destinations-details/?$ / [R=301,L]
RewriteRule ^destinations/?$ / [R=301,L]


# ── COMPRESSION (Gzip) ─────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── BROWSER CACHING ────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML - short CDN cache, revalidate on each request
  ExpiresByType text/html                  "access plus 5 minutes"

  # CSS + JS - 1 year (filenames include version via ?v= or are static)
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"

  # Images - 1 year
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts - 1 year
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType font/woff                  "access plus 1 year"
</IfModule>

# ── SECURITY HEADERS ───────────────────────────────────────
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # Cache-Control for static assets
  <FilesMatch "\.(css|js|png|jpg|jpeg|webp|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache-Control for HTML - allow CDN edge cache, revalidate each request
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ── HOTLINK PROTECTION ─────────────────────────────────────
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https://(www\.)?vajraaviation\.com [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?facebook\.com [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?fbcdn\.net [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?linkedin\.com [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?twitter\.com [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?t\.co [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?google\.com [NC]
RewriteCond %{HTTP_REFERER} !^https://lh[0-9]+\.googleusercontent\.com [NC]
RewriteRule \.(jpg|jpeg|png|gif|webp)$ - [F]

# ── DUPLICATE BLOG REDIRECT ──────────────────────────────────
RewriteRule ^blog-easa-part-66-b1-vs-b2/?$ /blog-easa-b1-vs-b2-guide [R=301,L]

# ── ERROR PAGES ────────────────────────────────────────────
ErrorDocument 404 /404.html
